# Copy to .env and fill in your values.

# LLM (OpenAI)
AG2EX__OPENAI_API_KEY=sk-your-openai-api-key
AG2EX__OPENAI_MODEL=gpt-4o-mini

# Optional HTTPS/SOCKS proxy for regions where api.openai.com is blocked.
# Examples: http://user:pass@proxy.example.com:8080  |  socks5://127.0.0.1:1080
# AG2EX__OPENAI_PROXY_URL=

# Database (PostgreSQL via psycopg3 async driver)
AG2EX__DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/note_db

# Logging
AG2EX__LOG_LEVEL=INFO
AG2EX__LOG_JSON=false
